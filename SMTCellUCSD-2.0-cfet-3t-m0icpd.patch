From a579bc0ef6426783f30b575e0cc755899fd8b37c Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursoragent@cursor.com>
Date: Fri, 26 Jun 2026 02:17:54 +0000
Subject: [PATCH 05/16] feat(cfet): BPC signal rows and overlap virtual connect
 for M0ICPD

---
 src/cellgen/archit/CFET/main.py | 14 ++++++++++----
 1 file changed, 10 insertions(+), 4 deletions(-)

diff --git a/src/cellgen/archit/CFET/main.py b/src/cellgen/archit/CFET/main.py
index 7fab619..916ae14 100644
--- a/src/cellgen/archit/CFET/main.py
+++ b/src/cellgen/archit/CFET/main.py
@@ -560,12 +560,18 @@ class CFET:
 
         # For vertical layers, specify rows so they connect to horizontal layers.
         # Top placement layer (directly accessible from M0) gets all M0 rows.
-        # Bottom placement layer only gets its boundary rows (first & last M0 rows)
-        # - interior rows are unreachable (no pins, no long vias) and bloat the model.
+        # Bottom placement layer uses boundary rows by default. For M0ICPD, BPC
+        # only exists on signal rows, so exclude the power rows.
         m0_rows = h_layer_rows.get("M0", [])
         top_layer = self.c_tech.get_top_placement_layer()
         bottom_layer = self.c_tech.get_bottom_placement_layer()
-        bottom_rows = [m0_rows[0], m0_rows[-1]] if len(m0_rows) >= 2 else m0_rows
+        if self.c_tech.power_config == "M0ICPD":
+            # BPC only on signal rows; exclude power rows 0 and 5.
+            bottom_rows = m0_rows[1:5] if len(m0_rows) >= 6 else m0_rows[1:-1]
+            vconnect_method = "overlap"
+        else:
+            bottom_rows = [m0_rows[0], m0_rows[-1]] if len(m0_rows) >= 2 else m0_rows
+            vconnect_method = "boundary"
         for layer in self.c_tech.layer_stack.metal_layers:
             if layer.direction == "V" and layer.layer_name == top_layer:
                 layer_to_rows[layer.layer_name] = m0_rows
@@ -582,7 +588,7 @@ class CFET:
             layer_to_direction=layer_to_direction,
             layer_to_kind=self.c_tech.layer_to_kind,
             virtual_connect_pairs=[("BPC", "M0")],
-            virtual_connect_method="boundary",
+            virtual_connect_method=vconnect_method,
         )
         self.lgg.stats()
 
-- 
