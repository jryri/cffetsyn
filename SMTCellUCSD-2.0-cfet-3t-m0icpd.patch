diff --git a/src/cellgen/archit/CFET/main.py b/src/cellgen/archit/CFET/main.py
index 29bfbc4..32f3475 100644
--- a/src/cellgen/archit/CFET/main.py
+++ b/src/cellgen/archit/CFET/main.py
@@ -563,16 +563,18 @@ class CFET:
 
         # For vertical layers, specify rows so they connect to horizontal layers.
         # Top placement layer (directly accessible from M0) gets all M0 rows.
-        # Bottom placement layer uses boundary rows by default. For M0ICPD, BPC
